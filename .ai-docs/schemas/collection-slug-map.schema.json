{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Collection Slug Map",
  "type": "object",
  "required": ["collections", "metadata"],
  "properties": {
    "collections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slug", "filePath"],
        "properties": {
          "slug": { "type": "string" },
          "filePath": { "type": "string" },
          "auth": { "type": ["boolean", "null"] },
          "versions": { "type": ["boolean", "null"] }
        },
        "additionalProperties": true
      }
    },
    "metadata": {
      "type": "object",
      "required": ["generatedAt", "totalCollections"],
      "properties": {
        "generatedAt": { "type": "string" },
        "totalCollections": { "type": "number" },
        "sourceRoot": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
