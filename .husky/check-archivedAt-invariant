#!/bin/sh
# Check that archivedAt: null is not used (except in normalization script)
# INVARIANT: Active = archivedAt field is MISSING. Archived = archivedAt field EXISTS.

# Allow skipping hooks
if [ "$SKIP_HOOKS" = "1" ]; then
  exit 0
fi

# Check staged files for archivedAt: null in object literals (not TypeScript types)
# Allowlist:
# - normalize-conversations-archivedAt.ts (finds and removes null values)
# - payload-types.ts (auto-generated, TypeScript types may include null)
# - check-archivedAt-invariant (this file, contains comments with null)
# - Documentation files
# - Files with only TypeScript type annotations (not object literal assignments)
violations=$(git diff --cached --name-only | xargs grep -lE "^\s*archivedAt\s*:\s*[^|]*null" 2>/dev/null | grep -v "normalize-conversations-archivedAt.ts" | grep -v "payload-types.ts" | grep -v "check-archivedAt-invariant" | grep -v "\.md$" || true)

if [ -n "$violations" ]; then
  echo ""
  echo "❌ ERROR: Found archivedAt: null in staged files"
  echo ""
  echo "INVARIANT: Active = archivedAt field is MISSING (not null)."
  echo ""
  echo "Violations found in:"
  echo "$violations" | sed 's/^/  - /'
  echo ""
  echo "Fix:"
  echo "  - For active conversations: Omit archivedAt field entirely"
  echo "  - For archived conversations: Set archivedAt: new Date()"
  echo ""
  echo "Allowed exception:"
  echo "  - scripts/normalize-conversations-archivedAt.ts (finds and removes null values)"
  echo ""
  echo "To skip this check:"
  echo "  SKIP_HOOKS=1 git commit"
  echo ""
  exit 1
fi

exit 0
