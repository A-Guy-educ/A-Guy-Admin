#!/bin/sh

. "$(dirname "$0")/skip-hooks.sh"

# Skip in CI environment
if [ -n "$GITHUB_ACTIONS" ] || [ -n "$CI" ]; then
  exit 0
fi

echo ""
echo "🚀 Running pre-push verification..."
echo ""

pnpm verify

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Pre-push verification failed. Push aborted."
  echo ""
  exit 1
fi

echo ""
echo "✅ Pre-push verification passed!"
echo ""
