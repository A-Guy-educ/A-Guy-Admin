{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_jungx4rp47fy_1","type":"tool_result","content":"1\t/**\n2\t * Lesson Duplication Orchestrator\n3\t *\n4\t * Drives the duplication pipeline for a single LessonDuplications record:\n5\t *  1. K2: Select up to 20 exercises from source lesson (via selectExercisesScaled)\n6\t *  2. For each exercise, concurrently (max 3):\n7\t *     a. Route to strategy (script or AI) → generates new exercise content\n8\t *     b. Run structural validator on the generated content\n9\t *     c. If structural passes AND strategy != 'script', run semantic validator\n10\t *     d. On any failure, append a failure entry to the LessonDuplications record\n11\t *  3. After all exercises settle: set status=succeeded (0 failures) or needs_review (>0 failures)\n12\t *\n13\t * Failures are streamed live — each failure is written to the DB immediately\n14\t * via payload.update(), not accumulated in memory.\n15\t */\n16\t\n17\timport type { Payload } from 'payload'\n18\timport type { Exercise } from '@/payload-types'\n19\timport type { ContentBlock } from '@/server/payload/collections/Exercises/schemas'\n20\timport type { DuplicationSubject } from '@/server/payload/collections/LessonDuplications'\n21\timport { logger } from '@/infra/utils/logger'\n22\timport {\n23\t  selectExercisesScaled,\n24\t  selectSectionsScaled,\n25\t} from '@/server/services/lesson-duplication/selectors'\n26\timport { getSourceExercisesForLesson } from '@/server/services/lesson-duplication/source-exercises'\n27\timport {\n28\t  validateExerciseStructural,\n29\t  fillMissingFieldsWithPlaceholders,\n30\t  BLOCKING_FAILURE_CODES,\n31\t  type StructuralFailure,\n32\t} from '@/server/services/lesson-duplication/validators/structural'\n33\timport {\n34\t  validateExerciseSemantic,\n35\t  SEMANTIC_FAILURE_CODE,\n36\t} from '@/server/services/lesson-duplication/validators/semantic'\n37\timport { RouterStrategy } from '@/server/services/lesson-duplication/strategies/router'\n38\timport { getModelCost } from '@/infra/llm/pricing'\n39\t\n40\t// Concurrency of 1 = process exercises sequentially. Each exercise hits the\n41\t// LLM twice (creative + deterministic). Gemini's per-minute quota is easily\n42\t// exceeded at higher concurrency, which triggered \"rate limit exceeded\"\n43\t// failures on every exercise in early multi-exercise runs. The variation\n44\t// service has rate-limit backoff as a safety net, but serializing is the\n45\t// primary control. Bump this back up only after we've sized the quota AND\n46\t// replaced appendEntry's read-modify-write with an atomic $push.\n47\t// `as const` pins the literal type so the compile-time guard below catches\n48\t// any bump (current value preserved as literal `1`).\n49\texport const CONCURRENCY_LIMIT = 1 as const\n50\t\n51\texport const GENERATION_FAILURE_CODE = 'GENERATION_FAILED' as const\n52\t\n53\texport type DuplicationStrategy = 'script' | 'ai'\n54\t\n55\t/** Result of running the strategy for one exercise. */\n56\texport interface StrategyResult {\n57\t  exerciseId: string\n58\t  strategy: DuplicationStrategy\n59\t  blocks: ContentBlock[]\n60\t}\n61\t\n62\t/**\n63\t * Generate a new exercise via the appropriate strategy.\n64\t *\n65\t * K3: ScriptVariationStrategy for purely-algebraic exercises at light level.\n66\t * K4: AiVariationStrategy for all other cases (throws until AI is wired up).\n67\t *\n68\t * @param exercise    Source exercise to vary\n69\t * @param level       Duplication level (none/light/medium/deep)\n70\t * @param _payload    Payload instance (available for future AI strategy use)\n71\t * @returns           StrategyResult with generated blocks and strategy used\n72\t */\n73\texport async function runStrategy(\n74\t  exercise: ExerciseDoc,\n75\t  level: 'none' | 'light' | 'medium' | 'deep',\n76\t  subject: DuplicationSubject,\n77\t  payload: Payload,\n78\t): Promise<StrategyResult & { tokensUsed: { inputTokens: number; outputTokens: number } }> {\n79\t  const router = new RouterStrategy(payload)\n80\t  const result = await router.apply(exercise as unknown as Exercise, level, subject)\n81\t\n82\t  const content = result.exercise.content as unknown as { blocks: ContentBlock[] }\n83\t  return {\n84\t    exerciseId: exercise.id,\n85\t    strategy: result.needsAiFallback ? 'ai' : 'script',\n86\t    blocks: content.blocks ?? [],\n87\t    tokensUsed: result.tokensUsed ?? { inputTokens: 0, outputTokens: 0 },\n88\t  }\n89\t}\n90\t\n91\t/**\n92\t * Cap source-exercise block count to match the structural validator's\n93\t * `TOO_MANY_SECTIONS` ceiling (5). Pure: returns a NEW exercise object with\n94\t * a trimmed `content.blocks` array when needed, otherwise the original.\n95\t *\n96\t * Picks 5 representative blocks from the source via `selectSectionsScaled` —\n97\t * the same scaling-random bucketing the lesson-level selector uses. Preserves\n98\t * source order, so the variation reads like a natural shorter version of the\n99\t * original rather than a random shuffle.\n100\t *\n101\t * Rationale: without this, a 10-block source always failed validation\n102\t * (TOO_MANY_SECTIONS is a blocking failure → exercise dropped from output).\n103\t * Admins doing deep variations on real lessons would silently lose any\n104\t * exercise that exceeded the block cap.\n105\t */\n106\tfunction trimSourceBlocksIfNeeded(exercise: ExerciseDoc): ExerciseDoc {\n107\t  const blocks = exercise.content?.blocks\n108\t  if (!Array.isArray(blocks) || blocks.length <= 5) return exercise\n109\t  const picked = selectSectionsScaled(blocks, 5)\n110\t  logger.info(\n111\t    { exerciseId: exercise.id, originalCount: blocks.length, trimmedTo: picked.length },\n112\t    'Source exercise has more than 5 blocks — trimming via scaling-random selector',\n113\t  )\n114\t  return {\n115\t    ...exercise,\n116\t    content: { ...exercise.content, blocks: picked },\n117\t  }\n118\t}\n119\t\n120\t/** Suggested action for a failure, based on failure code. */\n121\tfunction suggestAction(code: string): 'skip' | 'regenerate' | 'keep' {\n122\t  switch (code) {\n123\t    case 'MISSING_QUESTION':\n124\t    case 'MISSING_HINT':\n125\t    case 'MISSING_SOLUTION':\n126\t    case 'MISSING_FULL_SOLUTION':\n127\t    case 'MISSING_CORRECT_OPTION':\n128\t    case 'MISSING_WRONG_OPTIONS':\n129\t    case 'INVALID_SVG':\n130\t    case 'PNG_FORBIDDEN':\n131\t    case 'TOO_MANY_SECTIONS':\n132\t    case 'INVALID_GEOMETRY_SPEC':\n133\t    case 'INVALID_AXIS_SPEC':\n134\t    case 'INVALID_GUIDED_EXPLANATION':\n135\t      return 'regenerate'\n136\t    case 'SEMANTIC_MISMATCH':\n137\t      return 'regenerate'\n138\t    case 'GENERATION_FAILED':\n139\t      return 'skip'\n140\t    default:\n141\t      return 'skip'\n142\t  }\n143\t}\n144\t\n145\t// Compile-time guard: this whole module assumes CONCURRENCY_LIMIT === 1.\n146\t// appendEntry below uses a non-atomic read-then-update on the failures/warnings\n147\t// arrays — at concurrency >1 two parallel appends would race and lose entries.\n148\t// If you raise CONCURRENCY_LIMIT, replace appendEntry with a Mongo $push update\n149\t// before deleting this assert.\n150\ttype _AssertConcurrencyOne = typeof CONCURRENCY_LIMIT extends 1 ? true : never\n151\tconst _concurrencyAssert: _AssertConcurrencyOne = true\n152\tvoid _concurrencyAssert\n153\t\n154\t/**\n155\t * Append a single failure/warning entry to the LessonDuplications record.\n156\t *\n157\t * The bucket name is chosen by the caller:\n158\t *  - 'failures' = blocking; the exercise was dropped from the output lesson.\n159\t *  - 'warnings' = non-blocking; the exercise was kept with TODO placeholders\n160\t *    for the missing field. Admin polishes via the review screen.\n161\t */\n162\tasync function appendEntry(\n163\t  bucket: 'failures' | 'warnings',\n164\t  payload: Payload,\n165\t  duplicationId: string,\n166\t  exerciseRef: string,\n167\t  sectionIndex: number,\n168\t  code: string,\n169\t  message: string,\n170\t): Promise<void> {\n171\t  const action = suggestAction(code)\n172\t  try {\n173\t    const current = await payload.findByID({\n174\t      collection: 'lesson-duplications',\n175\t      id: duplicationId,\n176\t      depth: 0,\n177\t      overrideAccess: true,\n178\t    })\n179\t    await payload.update({\n180\t      collection: 'lesson-duplications',\n181\t      id: duplicationId,\n182\t      data: {\n183\t        [bucket]: [\n184\t          // eslint-disable-next-line @typescript-eslint/no-explicit-any\n185\t          ...(((current as any)[bucket] as any[]) ?? []),\n186\t          {\n187\t            exerciseRef,\n188\t            sectionIndex,\n189\t            code,\n190\t            message,\n191\t            suggestedAction: action,\n192\t            resolved: false,\n193\t          },\n194\t        ],\n195\t      } as never,\n196\t      overrideAccess: true,\n197\t    })\n198\t  } catch (err) {\n199\t    logger.error(\n200\t      { err, duplicationId, exerciseRef, code, bucket },\n201\t      `Failed to append ${bucket} entry to LessonDuplications`,\n202\t    )\n203\t    // Don't rethrow — streaming failure should not abort the run\n204\t  }\n205\t}\n206\t\n207\t/** Append a blocking failure (exercise dropped from output lesson). */\n208\tasync function appendFailure(\n209\t  payload: Payload,\n210\t  duplicationId: string,\n211\t  exerciseRef: string,\n212\t  sectionIndex: number,\n213\t  code: string,\n214\t  message: string,\n215\t): Promise<void> {\n216\t  return appendEntry('failures', payload, duplicationId, exerciseRef, sectionIndex, code, message)\n217\t}\n218\t\n219\t/** Append a non-blocking warning (exercise kept with placeholder). */\n220\tasync function appendWarning(\n221\t  payload: Payload,\n222\t  duplicationId: string,\n223\t  exerciseRef: string,\n224\t  sectionIndex: number,\n225\t  code: string,\n226\t  message: string,\n227\t): Promise<void> {\n228\t  return appendEntry('warnings', payload, duplicationId, exerciseRef, sectionIndex, code, message)\n229\t}\n230\t\n231\t/**\n232\t * Append a successful output-exercise mapping to the LessonDuplications\n233\t * record. Used to stream progress so a Vercel function timeout doesn't lose\n234\t * work that's already in the DB. Read-modify-write on the record's\n235\t * `outputExercises` array — safe under CONCURRENCY_LIMIT = 1.\n236\t */\n237\tasync function appendOutputExercise(\n238\t  payload: Payload,\n239\t  duplicationId: string,\n240\t  mapping: OutputExerciseMapping,\n241\t): Promise<void> {\n242\t  try {\n243\t    const current = await payload.findByID({\n244\t      collection: 'lesson-duplications',\n245\t      id: duplicationId,\n246\t      depth: 0,\n247\t      overrideAccess: true,\n248\t    })\n249\t    const existing =\n250\t      (current as unknown as { outputExercises?: OutputExerciseMapping[] }).outputExercises ?? []\n251\t    await payload.update({\n252\t      collection: 'lesson-duplications',\n253\t      id: duplicationId,\n254\t      data: { outputExercises: [...existing, mapping] } as never,\n255\t      overrideAccess: true,\n256\t    })\n257\t  } catch (err) {\n258\t    logger.error(\n259\t      { err, duplicationId, exerciseRef: mapping.sourceExerciseId },\n260\t      'Failed to append output exercise mapping',\n261\t    )\n262\t  }\n263\t}\n264\t\n265\t/** Shape of an exercise from the exercises collection. */\n266\ttype ExerciseDoc = {\n267\t  id: string\n268\t  content?: { blocks?: ContentBlock[] }\n269\t}\n270\t\n271\t/** Mapping entry from source exercise to generated output exercise. */\n272\tinterface OutputExerciseMapping {\n273\t  sourceExerciseId: string\n274\t  outputExerciseId: string\n275\t  strategy: DuplicationStrategy\n276\t}\n277\t\n278\t/**\n279\t * Create the output lesson (draft) by deep-copying every source-lesson field.\n280\t *\n281\t * Earlier versions only copied title/slug/status/chapter/course/tenant/locale,\n282\t * which dropped fields like accessType, visibleRenderers, blocks, contentStatus,\n283\t * and any custom flags the source lesson had. This caused variation outputs to\n284\t * be thinner than what the `none` endpoint produces. We now mirror the\n285\t * deep-clone behaviour of the `none` path so both routes produce equivalent\n286\t * lessons modulo the title suffix and a forced `draft` status.\n287\t */\n288\tasync function createOutputLesson(\n289\t  payload: Payload,\n290\t  sourceLessonId: string,\n291\t  level: string,\n292\t): Promise<string> {\n293\t  const source = await payload.findByID({\n294\t    collection: 'lessons',\n295\t    id: sourceLessonId,\n296\t    depth: 0,\n297\t    overrideAccess: true,\n298\t  })\n299\t  const sourceData = source as unknown as Record<string, unknown>\n300\t  // Drop Payload-managed + lineage fields; the rest carries over.\n301\t  //   slug:           regenerated by formatSlugAsync from the new title.\n302\t  //   blocks:         references source exercise IDs; rebuilt by the exercise\n303\t  //                   auto-add hook as new variation exercises are saved.\n304\t  //   translatedFrom: this is a fresh variation, not a translation copy.\n305\t  //   createdBy:      set to the duplicating admin via createdByField hook.\n306\t  const {\n307\t    id: _id,\n308\t    createdAt: _c,\n309\t    updatedAt: _u,\n310\t    slug: _ignoreSlug,\n311\t    blocks: _ignoreBlocks,\n312\t    translatedFrom: _ignoreTranslatedFrom,\n313\t    createdBy: _ignoreCreatedBy,\n314\t    ...rest\n315\t  } = sourceData as Record<string, unknown> & {\n316\t    id?: unknown\n317\t    createdAt?: unknown\n318\t    updatedAt?: unknown\n319\t    slug?: unknown\n320\t    blocks?: unknown\n321\t    translatedFrom?: unknown\n322\t    createdBy?: unknown\n323\t  }\n324\t  void _id\n325\t  void _c\n326\t  void _u\n327\t  void _ignoreSlug\n328\t  void _ignoreBlocks\n329\t  void _ignoreTranslatedFrom\n330\t  void _ignoreCreatedBy\n331\t  const base = (rest.title as string) ?? 'Lesson'\n332\t  const newLesson = await payload.create({\n333\t    collection: 'lessons',\n334\t    data: {\n335\t      ...rest,\n336\t      title: `${base} - Variation (${level})`,\n337\t      status: 'draft', // never publish a duplicate by default\n338\t    } as never,\n339\t    overrideAccess: true,\n340\t  })\n341\t  return newLesson.id\n342\t}\n343\t\n344\t/**\n345\t * Create a draft exercise in the output lesson with the generated blocks.\n346\t * Returns the mapping entry for tracking.\n347\t */\n348\tasync function createOutputExercise(\n349\t  payload: Payload,\n350\t  result: StrategyResult,\n351\t  outputLessonId: string,\n352\t): Promise<OutputExerciseMapping> {\n353\t  const ex = await payload.create({\n354\t    collection: 'exercises',\n355\t    data: {\n356\t      title: `Variation of ${result.exerciseId}`,\n357\t      lesson: outputLessonId,\n358\t      content: { blocks: result.blocks },\n359\t      status: 'draft',\n360\t    } as never,\n361\t    overrideAccess: true,\n362\t  })\n363\t  return {\n364\t    sourceExerciseId: result.exerciseId,\n365\t    outputExerciseId: ex.id,\n366\t    strategy: result.strategy,\n367\t  }\n368\t}\n369\t\n370\t/**\n371\t * Process a single exercise through the duplication pipeline.\n372\t *\n373\t * Steps:\n374\t *  1. Run strategy → get new exercise content\n375\t *  2. Structural validation → collect failures\n376\t *  3. If structural passes AND strategy != 'script' → semantic validation\n377\t *  4. On any failure: stream failure to DB, return null\n378\t *  5. On all pass: return StrategyResult for the orchestrator to use\n379\t */\n380\tasync function processExercise(\n381\t  exercise: ExerciseDoc,\n382\t  duplicationId: string,\n383\t  level: 'none' | 'light' | 'medium' | 'deep',\n384\t  subject: DuplicationSubject,\n385\t  payload: Payload,\n386\t): Promise<{\n387\t  result: StrategyResult | null\n388\t  tokensUsed: { inputTokens: number; outputTokens: number }\n389\t}> {\n390\t  const exerciseRef = exercise.id\n391\t\n392\t  // Pre-trim source blocks. The structural validator caps exercises at 5\n393\t  // blocks (TOO_MANY_SECTIONS — renderer / UX limit). Source exercises with\n394\t  // 9-10 blocks would always fail variation. We sub-sample to 5 using the\n395\t  // same scaling-random selector that picks exercises from a lesson: pick 1\n396\t  // block per evenly-spaced bucket across the source, seeded for\n397\t  // reproducibility. Preserves source order, so the variation feels like a\n398\t  // natural truncation of the original.\n399\t  const trimmedExercise = trimSourceBlocksIfNeeded(exercise)\n400\t\n401\t  // Step 1: Run strategy\n402\t  let strategyResult: StrategyResult\n403\t  let tokensUsed = { inputTokens: 0, outputTokens: 0 }\n404\t  try {\n405\t<<<<<<< HEAD\n406\t    const strategyResponse = await runStrategy(exercise, level, subject, payload)\n407\t    strategyResult = strategyResponse\n408\t    tokensUsed = strategyResponse.tokensUsed\n409\t=======\n410\t    strategyResult = await runStrategy(trimmedExercise, level, subject, payload)\n411\t>>>>>>> origin/dev\n412\t  } catch (err) {\n413\t    const message = err instanceof Error ? err.message : 'Unknown strategy error'\n414\t    logger.error({ exerciseRef, level, err }, 'Strategy generation failed')\n415\t    await appendFailure(payload, duplicationId, exerciseRef, 0, GENERATION_FAILURE_CODE, message)\n416\t    return { result: null, tokensUsed }\n417\t  }\n418\t\n419\t  // Step 2: Structural validation. Split failures into blocking (drop the\n420\t  // exercise — renderer would crash) and warnings (admin fills from review\n421\t  // screen). Warning-only exercises still ship, with TODO placeholders filled\n422\t  // in for missing hint/solution/fullSolution so the lesson stays renderable.\n423\t  //\n424\t  // We pass the source exercise's blocks (post-trim) so the validator can\n425\t  // suppress MISSING_QUESTION when the source itself had an empty prompt\n426\t  // (e.g. legacy geometry exercises where the question is in the figure, not\n427\t  // as text). Otherwise every such variation would falsely fail.\n428\t  const sourceBlocks = (trimmedExercise.content?.blocks ?? []) as ContentBlock[]\n429\t  const structuralFailures: StructuralFailure[] = validateExerciseStructural(\n430\t    strategyResult.blocks,\n431\t    sourceBlocks,\n432\t  )\n433\t  const blockingFailures = structuralFailures.filter((f) => BLOCKING_FAILURE_CODES.has(f.code))\n434\t  const warningFailures = structuralFailures.filter((f) => !BLOCKING_FAILURE_CODES.has(f.code))\n435\t\n436\t  // Record blocking failures and non-blocking warnings into separate buckets\n437\t  // so the review UI can show them under different headings.\n438\t  for (const failure of blockingFailures) {\n439\t    await appendFailure(\n440\t      payload,\n441\t      duplicationId,\n442\t      exerciseRef,\n443\t      failure.blockIndex ?? 0,\n444\t      failure.code,\n445\t      failure.message,\n446\t    )\n447\t  }\n448\t  for (const warning of warningFailures) {\n449\t    await appendWarning(\n450\t      payload,\n451\t      duplicationId,\n452\t      exerciseRef,\n453\t      warning.blockIndex ?? 0,\n454\t      warning.code,\n455\t      warning.message,\n456\t    )\n457\t  }\n458\t\n459\t  if (blockingFailures.length > 0) {\n460\t    return { result: null, tokensUsed }\n461\t  }\n462\t\n463\t  // Warning-only path: fill placeholders so the exercise renders. Warnings are\n464\t  // already recorded so the admin can find the TODOs in the review screen.\n465\t  if (warningFailures.length > 0) {\n466\t    strategyResult = {\n467\t      ...strategyResult,\n468\t      blocks: fillMissingFieldsWithPlaceholders(strategyResult.blocks),\n469\t    }\n470\t  }\n471\t\n472\t  // Step 3: Semantic validation. Skipped for:\n473\t  //  - level=none (deep clone, no AI variation to judge)\n474\t  //  - script strategy (deterministic, no hallucination risk)\n475\t  //  - warning-only path (we just inserted \"_TODO: hint not provided by AI_\"\n476\t  //    placeholders; a semantic reviewer would flag those as nonsensical and\n477\t  //    demote an exercise that should ship with a polish-later flag into a\n478\t  //    hard failure)\n479\t  if (strategyResult.strategy !== 'script' && level !== 'none' && warningFailures.length === 0) {\n480\t    const semanticResult = await validateExerciseSemantic(\n481\t      strategyResult.blocks,\n482\t      level,\n483\t      strategyResult.strategy,\n484\t      payload,\n485\t    )\n486\t    if (!semanticResult.ok) {\n487\t      await appendFailure(\n488\t        payload,\n489\t        duplicationId,\n490\t        exerciseRef,\n491\t        0,\n492\t        SEMANTIC_FAILURE_CODE,\n493\t        `Semantic mismatch: ${semanticResult.reasons.join('; ')}`,\n494\t      )\n495\t      return { result: null, tokensUsed }\n496\t    }\n497\t  }\n498\t\n499\t  return { result: strategyResult, tokensUsed }\n500\t}\n501\t\n502\t/**\n503\t * Reserve at least this much wall time (ms) at the end of a tick so the\n504\t * orchestrator can write its final state to the DB before the platform\n505\t * (Vercel) yanks the function. 30s covers a slow Mongo round-trip plus\n506\t * Vercel's teardown grace.\n507\t */\n508\tconst FINALIZE_BUDGET_MS = 30_000\n509\t\n510\t/**\n511\t * Default assumed worst-case time for one exercise (pass-1 + pass-2 +\n512\t * validators on gemini-3.1-pro-preview). Used to decide whether the next\n513\t * exercise can fit before the deadline. Conservative — if the run is\n514\t * faster, we just process more per tick.\n515\t */\n516\tconst ASSUMED_EXERCISE_DURATION_MS = 300_000\n517\t\n518\texport type RunOutcome = 'succeeded' | 'needs_review' | 'failed' | 'in_progress'\n519\t\n520\texport interface RunOptions {\n521\t  /**\n522\t   * Absolute wall-clock deadline (Date.now() ms). The orchestrator returns\n523\t   * `in_progress` as soon as the remaining time is too short to fit another\n524\t   * exercise — leaving the record in `running` so the next cron tick picks\n525\t   * up where this one left off. Default: no deadline (process all).\n526\t   */\n527\t  deadlineMs?: number\n528\t}\n529\t\n530\t/**\n531\t * Orchestrate the duplication pipeline for a single LessonDuplications record.\n532\t * Resumable: skips exercises already processed in previous ticks and streams\n533\t * each new output mapping to the DB as it completes. A Vercel function\n534\t * timeout mid-run leaves a clean partial state — the next cron tick continues\n535\t * from there.\n536\t *\n537\t * @param duplicationId  ID of the LessonDuplications record to process\n538\t * @param payload        Payload instance\n539\t * @param options.deadlineMs  Absolute timestamp by which to stop processing\n540\t *\n541\t * Pre-condition: record has status `pending` (fresh) or `running` (resuming).\n542\t * Post-condition (returned outcome):\n543\t *  - 'succeeded'   — all picked exercises produced an output, 0 failures\n544\t *  - 'needs_review'— all picked exercises terminal, ≥1 failure\n545\t *  - 'in_progress' — deadline hit, more work to do, status left as 'running'\n546\t *  - 'failed'      — fatal error before any exercises processed\n547\t */\n548\texport async function runDuplicationOrchestrator(\n549\t  duplicationId: string,\n550\t  payload: Payload,\n551\t  options: RunOptions = {},\n552\t): Promise<RunOutcome> {\n553\t  // Load the duplication record\n554\t  const duplication = await payload.findByID({\n555\t    collection: 'lesson-duplications',\n556\t    id: duplicationId,\n557\t    depth: 1, // need sourceLesson relationship\n558\t    overrideAccess: true,\n559\t  })\n560\t\n561\t  if (!duplication) {\n562\t    logger.error({ duplicationId }, 'LessonDuplications record not found')\n563\t    return 'failed'\n564\t  }\n565\t\n566\t  // Already terminal — nothing to do.\n567\t  if (\n568\t    duplication.status === 'succeeded' ||\n569\t    duplication.status === 'needs_review' ||\n570\t    duplication.status === 'failed'\n571\t  ) {\n572\t    logger.warn(\n573\t      { duplicationId, status: duplication.status },\n574\t      'LessonDuplications record already terminal, skipping',\n575\t    )\n576\t    return duplication.status as RunOutcome\n577\t  }\n578\t\n579\t  // Accept both 'pending' (first tick) and 'running' (resuming) — anything\n580\t  // else is unexpected.\n581\t  if (duplication.status !== 'pending' && duplication.status !== 'running') {\n582\t    logger.warn(\n583\t      { duplicationId, status: duplication.status },\n584\t      'LessonDuplications record in unexpected status, skipping',\n585\t    )\n586\t    return 'failed'\n587\t  }\n588\t\n589\t  // Token accumulators and timing for AI telemetry (issue #1552)\n590\t  const runStartTime = Date.now()\n591\t  let totalAiTokensInput = 0\n592\t  let totalAiTokensOutput = 0\n593\t\n594\t  try {\n595\t    const sourceLessonId =\n596\t      typeof duplication.sourceLesson === 'string'\n597\t        ? duplication.sourceLesson\n598\t        : (duplication.sourceLesson as { id?: string })?.id\n599\t\n600\t    if (!sourceLessonId) {\n601\t      throw new Error('sourceLesson relationship is missing or invalid')\n602\t    }\n603\t\n604\t    // First tick: create output lesson, flip to running. Resuming tick:\n605\t    // reuse the existing output lesson recorded on the record.\n606\t    let outputLessonId: string\n607\t    const existingOutputLessonRef = duplication.outputLesson as\n608\t      | string\n609\t      | { id?: string }\n610\t      | null\n611\t      | undefined\n612\t    const existingOutputLessonId =\n613\t      typeof existingOutputLessonRef === 'string'\n614\t        ? existingOutputLessonRef\n615\t        : existingOutputLessonRef?.id\n616\t\n617\t    if (duplication.status === 'pending') {\n618\t      outputLessonId = await createOutputLesson(\n619\t        payload,\n620\t        sourceLessonId,\n621\t        duplication.level ?? 'light',\n622\t      )\n623\t      await payload.update({\n624\t        collection: 'lesson-duplications',\n625\t        id: duplicationId,\n626\t        data: { status: 'running', outputLesson: outputLessonId } as never,\n627\t        overrideAccess: true,\n628\t      })\n629\t    } else {\n630\t      // resuming\n631\t      if (!existingOutputLessonId) {\n632\t        // Shouldn't happen — running record without an outputLesson means a\n633\t        // previous tick crashed before the initial write. Treat as fresh.\n634\t        outputLessonId = await createOutputLesson(\n635\t          payload,\n636\t          sourceLessonId,\n637\t          duplication.level ?? 'light',\n638\t        )\n639\t        await payload.update({\n640\t          collection: 'lesson-duplications',\n641\t          id: duplicationId,\n642\t          data: { outputLesson: outputLessonId } as never,\n643\t          overrideAccess: true,\n644\t        })\n645\t      } else {\n646\t        outputLessonId = existingOutputLessonId\n647\t      }\n648\t    }\n649\t\n650\t    const allExercises = await getSourceExercisesForLesson(payload, sourceLessonId)\n651\t\n652\t    // No artificial cap — resumability handles long runs across multiple\n653\t    // cron ticks. selectExercisesScaled still bounds at 20 per the original\n654\t    // product spec (admin scaling-random across the whole lesson).\n655\t    const PER_RUN_EXERCISE_CAP = 20\n656\t    const selectedExercises = selectExercisesScaled(\n657\t      allExercises as ExerciseDoc[],\n658\t      PER_RUN_EXERCISE_CAP,\n659\t    )\n660\t\n661\t    // Filter out exercises already processed on prior ticks. Sources of truth:\n662\t    //  1. The record's `outputExercises` — explicitly recorded successes.\n663\t    //  2. The record's `failures` — terminal per-exercise failures.\n664\t    //  3. Output exercises already present in the output lesson itself, even\n665\t    //     if their mapping never made it back into `outputExercises`. This\n666\t    //     closes the crash-window between createOutputExercise (writes the\n667\t    //     exercise to Mongo) and appendOutputExercise (records the mapping):\n668\t    //     if the function dies between those two calls, the exercise is\n669\t    //     durably saved but the record doesn't know about it; without this\n670\t    //     check the next tick would re-process the source and create a\n671\t    //     duplicate. We identify the source by the deterministic title\n672\t    //     `Variation of <sourceExerciseId>` set in createOutputExercise.\n673\t    const existingOutputExercises = await payload.find({\n674\t      collection: 'exercises',\n675\t      where: { lesson: { equals: outputLessonId } },\n676\t      limit: 0,\n677\t      depth: 0,\n678\t      overrideAccess: true,\n679\t    })\n680\t    const titleSourceIds = new Set<string>()\n681\t    const orphanMappings: OutputExerciseMapping[] = []\n682\t    const knownMappingSources = new Set(\n683\t      ((duplication.outputExercises as unknown as OutputExerciseMapping[]) ?? []).map(\n684\t        (m) => m.sourceExerciseId,\n685\t      ),\n686\t    )\n687\t    for (const ex of existingOutputExercises.docs as Array<{\n688\t      id: string\n689\t      title?: string\n690\t    }>) {\n691\t      const match = typeof ex.title === 'string' ? /^Variation of (\\S+)/.exec(ex.title) : null\n692\t      if (match) {\n693\t        titleSourceIds.add(match[1])\n694\t        // Recover the mapping for any orphan exercise (created but never\n695\t        // recorded). Next tick start, we'll reconcile by appending these\n696\t        // mappings so the record matches reality going forward.\n697\t        if (!knownMappingSources.has(match[1])) {\n698\t          orphanMappings.push({\n699\t            sourceExerciseId: match[1],\n700\t            outputExerciseId: ex.id,\n701\t            strategy: 'ai',\n702\t          })\n703\t        }\n704\t      }\n705\t    }\n706\t\n707\t    // Reconcile orphan mappings recovered from the output lesson so the\n708\t    // duplications record reflects reality before this tick continues.\n709\t    for (const orphan of orphanMappings) {\n710\t      await appendOutputExercise(payload, duplicationId, orphan)\n711\t      logger.warn(\n712\t        { duplicationId, sourceExerciseId: orphan.sourceExerciseId },\n713\t        '[orchestrator] Recovered orphan output exercise (crash-window mapping)',\n714\t      )\n715\t    }\n716\t\n717\t    const processedIds = new Set<string>([\n718\t      ...((duplication.outputExercises as unknown as OutputExerciseMapping[]) ?? []).map(\n719\t        (m) => m.sourceExerciseId,\n720\t      ),\n721\t      ...((duplication.failures as unknown as Array<{ exerciseRef: string }>) ?? []).map(\n722\t        (f) => f.exerciseRef,\n723\t      ),\n724\t      ...titleSourceIds,\n725\t    ])\n726\t    const remaining = selectedExercises.filter((ex) => !processedIds.has(ex.id))\n727\t\n728\t    logger.info(\n729\t      {\n730\t        duplicationId,\n731\t        totalPicked: selectedExercises.length,\n732\t        alreadyProcessed: selectedExercises.length - remaining.length,\n733\t        remaining: remaining.length,\n734\t      },\n735\t      'Orchestrator tick start',\n736\t    )\n737\t\n738\t    const duplicationLevel = duplication.level as 'none' | 'light' | 'medium' | 'deep'\n739\t    const duplicationSubject =\n740\t      (duplication.subject as DuplicationSubject | null | undefined) ?? 'mixed'\n741\t\n742\t    // Process exercises one at a time (CONCURRENCY_LIMIT = 1 — appendEntry's\n743\t    // read-modify-write isn't safe under parallel writes; see compile-time\n744\t    // guard). Check deadline between exercises and bail out if the next one\n745\t    // can't fit, returning `in_progress` so the next tick continues.\n746\t    for (const exercise of remaining) {\n747\t      if (options.deadlineMs !== undefined) {\n748\t        const remainingMs = options.deadlineMs - Date.now()\n749\t        if (remainingMs < FINALIZE_BUDGET_MS + ASSUMED_EXERCISE_DURATION_MS) {\n750\t          logger.info(\n751\t            { duplicationId, remainingMs, remainingExercises: remaining.length },\n752\t            'Orchestrator tick yielding before deadline — leaving record running',\n753\t          )\n754\t          return 'in_progress'\n755\t        }\n756\t      }\n757\t\n758\t      const { result, tokensUsed } = await processExercise(\n759\t        exercise,\n760\t        duplicationId,\n761\t        duplicationLevel,\n762\t        duplicationSubject,\n763\t        payload,\n764\t      )\n765\t      // Accumulate token usage across all exercises (issue #1552)\n766\t      totalAiTokensInput += tokensUsed.inputTokens\n767\t      totalAiTokensOutput += tokensUsed.outputTokens\n768\t      if (result === null) continue // failure already recorded by processExercise\n769\t\n770\t      try {\n771\t        const mapping = await createOutputExercise(payload, result, outputLessonId)\n772\t        // Stream the success immediately so a function timeout doesn't lose\n773\t        // this exercise — the actual exercise doc is already in MongoDB\n774\t        // (createOutputExercise just created it), this just keeps the\n775\t        // duplications record in sync.\n776\t        await appendOutputExercise(payload, duplicationId, mapping)\n777\t      } catch (err) {\n778\t        const message = err instanceof Error ? err.message : 'Unknown create error'\n779\t        logger.error(\n780\t          { exerciseRef: exercise.id, err },\n781\t          'createOutputExercise failed — exercise dropped from output lesson',\n782\t        )\n783\t        await appendFailure(\n784\t          payload,\n785\t          duplicationId,\n786\t          exercise.id,\n787\t          0,\n788\t          GENERATION_FAILURE_CODE,\n789\t          `Failed to save variation: ${message}`,\n790\t        )\n791\t      }\n792\t    }\n793\t\n794\t    // All selected exercises terminal: finalize status. Re-read failures\n795\t    // count from the record since we streamed entries during the run.\n796\t    const finalRecord = await payload.findByID({\n797\t      collection: 'lesson-duplications',\n798\t      id: duplicationId,\n799\t      depth: 0,\n800\t      overrideAccess: true,\n801\t    })\n802\t    const finalFailures = (finalRecord.failures as unknown as unknown[] | undefined)?.length ?? 0\n803\t    const finalOutputs =\n804\t      (finalRecord.outputExercises as unknown as unknown[] | undefined)?.length ?? 0\n805\t    const finalStatus: 'succeeded' | 'needs_review' =\n806\t      finalFailures === 0 ? 'succeeded' : 'needs_review'\n807\t\n808\t    logger.info(\n809\t      {\n810\t        duplicationId,\n811\t        total: selectedExercises.length,\n812\t        succeeded: finalOutputs,\n813\t        failed: finalFailures,\n814\t        finalStatus,\n815\t      },\n816\t      'Duplication orchestrator completed',\n817\t    )\n818\t\n819\t    const runDurationMs = Date.now() - runStartTime\n820\t    // Compute cost using gemini-3.1-pro as the representative model (issue #1552)\n821\t    const aiCostUsd = getModelCost('gemini-3.1-pro', totalAiTokensInput, totalAiTokensOutput)\n822\t    await payload.update({\n823\t      collection: 'lesson-duplications',\n824\t      id: duplicationId,\n825\t      data: {\n826\t        status: finalStatus,\n827\t        aiTokensInput: totalAiTokensInput,\n828\t        aiTokensOutput: totalAiTokensOutput,\n829\t        aiCostUsd,\n830\t        runDurationMs,\n831\t      } as never,\n832\t      overrideAccess: true,\n833\t    })\n834\t    return finalStatus\n835\t  } catch (err) {\n836\t    logger.error({ duplicationId, err }, 'Orchestrator run failed')\n837\t    await payload.update({\n838\t      collection: 'lesson-duplications',\n839\t      id: duplicationId,\n840\t      data: { status: 'failed' },\n841\t      overrideAccess: true,\n842\t    })\n843\t    throw err\n844\t  }\n845\t}\n846\t"}]},"parent_tool_use_id":null,"session_id":"f2b408d9-67e3-4e0b-adf2-7a296d3f9cd6","uuid":"17cb4303-2e47-4026-95f6-b68b735b2cbe","timestamp":"2026-05-14T13:30:51.636Z","tool_use_result":{"type":"text","file":{"filePath":"/home/runner/work/A-Guy/A-Guy/src/server/services/lesson-duplication/orchestrator.ts","content":"/**\n * Lesson Duplication Orchestrator\n *\n * Drives the duplication pipeline for a single LessonDuplications record:\n *  1. K2: Select up to 20 exercises from source lesson (via selectExercisesScaled)\n *  2. For each exercise, concurrently (max 3):\n *     a. Route to strategy (script or AI) → generates new exercise content\n *     b. Run structural validator on the generated content\n *     c. If structural passes AND strategy != 'script', run semantic validator\n *     d. On any failure, append a failure entry to the LessonDuplications record\n *  3. After all exercises settle: set status=succeeded (0 failures) or needs_review (>0 failures)\n *\n * Failures are streamed live — each failure is written to the DB immediately\n * via payload.update(), not accumulated in memory.\n */\n\nimport type { Payload } from 'payload'\nimport type { Exercise } from '@/payload-types'\nimport type { ContentBlock } from '@/server/payload/collections/Exercises/schemas'\nimport type { DuplicationSubject } from '@/server/payload/collections/LessonDuplications'\nimport { logger } from '@/infra/utils/logger'\nimport {\n  selectExercisesScaled,\n  selectSectionsScaled,\n} from '@/server/services/lesson-duplication/selectors'\nimport { getSourceExercisesForLesson } from '@/server/services/lesson-duplication/source-exercises'\nimport {\n  validateExerciseStructural,\n  fillMissingFieldsWithPlaceholders,\n  BLOCKING_FAILURE_CODES,\n  type StructuralFailure,\n} from '@/server/services/lesson-duplication/validators/structural'\nimport {\n  validateExerciseSemantic,\n  SEMANTIC_FAILURE_CODE,\n} from '@/server/services/lesson-duplication/validators/semantic'\nimport { RouterStrategy } from '@/server/services/lesson-duplication/strategies/router'\nimport { getModelCost } from '@/infra/llm/pricing'\n\n// Concurrency of 1 = process exercises sequentially. Each exercise hits the\n// LLM twice (creative + deterministic). Gemini's per-minute quota is easily\n// exceeded at higher concurrency, which triggered \"rate limit exceeded\"\n// failures on every exercise in early multi-exercise runs. The variation\n// service has rate-limit backoff as a safety net, but serializing is the\n// primary control. Bump this back up only after we've sized the quota AND\n// replaced appendEntry's read-modify-write with an atomic $push.\n// `as const` pins the literal type so the compile-time guard below catches\n// any bump (current value preserved as literal `1`).\nexport const CONCURRENCY_LIMIT = 1 as const\n\nexport const GENERATION_FAILURE_CODE = 'GENERATION_FAILED' as const\n\nexport type DuplicationStrategy = 'script' | 'ai'\n\n/** Result of running the strategy for one exercise. */\nexport interface StrategyResult {\n  exerciseId: string\n  strategy: DuplicationStrategy\n  blocks: ContentBlock[]\n}\n\n/**\n * Generate a new exercise via the appropriate strategy.\n *\n * K3: ScriptVariationStrategy for purely-algebraic exercises at light level.\n * K4: AiVariationStrategy for all other cases (throws until AI is wired up).\n *\n * @param exercise    Source exercise to vary\n * @param level       Duplication level (none/light/medium/deep)\n * @param _payload    Payload instance (available for future AI strategy use)\n * @returns           StrategyResult with generated blocks and strategy used\n */\nexport async function runStrategy(\n  exercise: ExerciseDoc,\n  level: 'none' | 'light' | 'medium' | 'deep',\n  subject: DuplicationSubject,\n  payload: Payload,\n): Promise<StrategyResult & { tokensUsed: { inputTokens: number; outputTokens: number } }> {\n  const router = new RouterStrategy(payload)\n  const result = await router.apply(exercise as unknown as Exercise, level, subject)\n\n  const content = result.exercise.content as unknown as { blocks: ContentBlock[] }\n  return {\n    exerciseId: exercise.id,\n    strategy: result.needsAiFallback ? 'ai' : 'script',\n    blocks: content.blocks ?? [],\n    tokensUsed: result.tokensUsed ?? { inputTokens: 0, outputTokens: 0 },\n  }\n}\n\n/**\n * Cap source-exercise block count to match the structural validator's\n * `TOO_MANY_SECTIONS` ceiling (5). Pure: returns a NEW exercise object with\n * a trimmed `content.blocks` array when needed, otherwise the original.\n *\n * Picks 5 representative blocks from the source via `selectSectionsScaled` —\n * the same scaling-random bucketing the lesson-level selector uses. Preserves\n * source order, so the variation reads like a natural shorter version of the\n * original rather than a random shuffle.\n *\n * Rationale: without this, a 10-block source always failed validation\n * (TOO_MANY_SECTIONS is a blocking failure → exercise dropped from output).\n * Admins doing deep variations on real lessons would silently lose any\n * exercise that exceeded the block cap.\n */\nfunction trimSourceBlocksIfNeeded(exercise: ExerciseDoc): ExerciseDoc {\n  const blocks = exercise.content?.blocks\n  if (!Array.isArray(blocks) || blocks.length <= 5) return exercise\n  const picked = selectSectionsScaled(blocks, 5)\n  logger.info(\n    { exerciseId: exercise.id, originalCount: blocks.length, trimmedTo: picked.length },\n    'Source exercise has more than 5 blocks — trimming via scaling-random selector',\n  )\n  return {\n    ...exercise,\n    content: { ...exercise.content, blocks: picked },\n  }\n}\n\n/** Suggested action for a failure, based on failure code. */\nfunction suggestAction(code: string): 'skip' | 'regenerate' | 'keep' {\n  switch (code) {\n    case 'MISSING_QUESTION':\n    case 'MISSING_HINT':\n    case 'MISSING_SOLUTION':\n    case 'MISSING_FULL_SOLUTION':\n    case 'MISSING_CORRECT_OPTION':\n    case 'MISSING_WRONG_OPTIONS':\n    case 'INVALID_SVG':\n    case 'PNG_FORBIDDEN':\n    case 'TOO_MANY_SECTIONS':\n    case 'INVALID_GEOMETRY_SPEC':\n    case 'INVALID_AXIS_SPEC':\n    case 'INVALID_GUIDED_EXPLANATION':\n      return 'regenerate'\n    case 'SEMANTIC_MISMATCH':\n      return 'regenerate'\n    case 'GENERATION_FAILED':\n      return 'skip'\n    default:\n      return 'skip'\n  }\n}\n\n// Compile-time guard: this whole module assumes CONCURRENCY_LIMIT === 1.\n// appendEntry below uses a non-atomic read-then-update on the failures/warnings\n// arrays — at concurrency >1 two parallel appends would race and lose entries.\n// If you raise CONCURRENCY_LIMIT, replace appendEntry with a Mongo $push update\n// before deleting this assert.\ntype _AssertConcurrencyOne = typeof CONCURRENCY_LIMIT extends 1 ? true : never\nconst _concurrencyAssert: _AssertConcurrencyOne = true\nvoid _concurrencyAssert\n\n/**\n * Append a single failure/warning entry to the LessonDuplications record.\n *\n * The bucket name is chosen by the caller:\n *  - 'failures' = blocking; the exercise was dropped from the output lesson.\n *  - 'warnings' = non-blocking; the exercise was kept with TODO placeholders\n *    for the missing field. Admin polishes via the review screen.\n */\nasync function appendEntry(\n  bucket: 'failures' | 'warnings',\n  payload: Payload,\n  duplicationId: string,\n  exerciseRef: string,\n  sectionIndex: number,\n  code: string,\n  message: string,\n): Promise<void> {\n  const action = suggestAction(code)\n  try {\n    const current = await payload.findByID({\n      collection: 'lesson-duplications',\n      id: duplicationId,\n      depth: 0,\n      overrideAccess: true,\n    })\n    await payload.update({\n      collection: 'lesson-duplications',\n      id: duplicationId,\n      data: {\n        [bucket]: [\n          // eslint-disable-next-line @typescript-eslint/no-explicit-any\n          ...(((current as any)[bucket] as any[]) ?? []),\n          {\n            exerciseRef,\n            sectionIndex,\n            code,\n            message,\n            suggestedAction: action,\n            resolved: false,\n          },\n        ],\n      } as never,\n      overrideAccess: true,\n    })\n  } catch (err) {\n    logger.error(\n      { err, duplicationId, exerciseRef, code, bucket },\n      `Failed to append ${bucket} entry to LessonDuplications`,\n    )\n    // Don't rethrow — streaming failure should not abort the run\n  }\n}\n\n/** Append a blocking failure (exercise dropped from output lesson). */\nasync function appendFailure(\n  payload: Payload,\n  duplicationId: string,\n  exerciseRef: string,\n  sectionIndex: number,\n  code: string,\n  message: string,\n): Promise<void> {\n  return appendEntry('failures', payload, duplicationId, exerciseRef, sectionIndex, code, message)\n}\n\n/** Append a non-blocking warning (exercise kept with placeholder). */\nasync function appendWarning(\n  payload: Payload,\n  duplicationId: string,\n  exerciseRef: string,\n  sectionIndex: number,\n  code: string,\n  message: string,\n): Promise<void> {\n  return appendEntry('warnings', payload, duplicationId, exerciseRef, sectionIndex, code, message)\n}\n\n/**\n * Append a successful output-exercise mapping to the LessonDuplications\n * record. Used to stream progress so a Vercel function timeout doesn't lose\n * work that's already in the DB. Read-modify-write on the record's\n * `outputExercises` array — safe under CONCURRENCY_LIMIT = 1.\n */\nasync function appendOutputExercise(\n  payload: Payload,\n  duplicationId: string,\n  mapping: OutputExerciseMapping,\n): Promise<void> {\n  try {\n    const current = await payload.findByID({\n      collection: 'lesson-duplications',\n      id: duplicationId,\n      depth: 0,\n      overrideAccess: true,\n    })\n    const existing =\n      (current as unknown as { outputExercises?: OutputExerciseMapping[] }).outputExercises ?? []\n    await payload.update({\n      collection: 'lesson-duplications',\n      id: duplicationId,\n      data: { outputExercises: [...existing, mapping] } as never,\n      overrideAccess: true,\n    })\n  } catch (err) {\n    logger.error(\n      { err, duplicationId, exerciseRef: mapping.sourceExerciseId },\n      'Failed to append output exercise mapping',\n    )\n  }\n}\n\n/** Shape of an exercise from the exercises collection. */\ntype ExerciseDoc = {\n  id: string\n  content?: { blocks?: ContentBlock[] }\n}\n\n/** Mapping entry from source exercise to generated output exercise. */\ninterface OutputExerciseMapping {\n  sourceExerciseId: string\n  outputExerciseId: string\n  strategy: DuplicationStrategy\n}\n\n/**\n * Create the output lesson (draft) by deep-copying every source-lesson field.\n *\n * Earlier versions only copied title/slug/status/chapter/course/tenant/locale,\n * which dropped fields like accessType, visibleRenderers, blocks, contentStatus,\n * and any custom flags the source lesson had. This caused variation outputs to\n * be thinner than what the `none` endpoint produces. We now mirror the\n * deep-clone behaviour of the `none` path so both routes produce equivalent\n * lessons modulo the title suffix and a forced `draft` status.\n */\nasync function createOutputLesson(\n  payload: Payload,\n  sourceLessonId: string,\n  level: string,\n): Promise<string> {\n  const source = await payload.findByID({\n    collection: 'lessons',\n    id: sourceLessonId,\n    depth: 0,\n    overrideAccess: true,\n  })\n  const sourceData = source as unknown as Record<string, unknown>\n  // Drop Payload-managed + lineage fields; the rest carries over.\n  //   slug:           regenerated by formatSlugAsync from the new title.\n  //   blocks:         references source exercise IDs; rebuilt by the exercise\n  //                   auto-add hook as new variation exercises are saved.\n  //   translatedFrom: this is a fresh variation, not a translation copy.\n  //   createdBy:      set to the duplicating admin via createdByField hook.\n  const {\n    id: _id,\n    createdAt: _c,\n    updatedAt: _u,\n    slug: _ignoreSlug,\n    blocks: _ignoreBlocks,\n    translatedFrom: _ignoreTranslatedFrom,\n    createdBy: _ignoreCreatedBy,\n    ...rest\n  } = sourceData as Record<string, unknown> & {\n    id?: unknown\n    createdAt?: unknown\n    updatedAt?: unknown\n    slug?: unknown\n    blocks?: unknown\n    translatedFrom?: unknown\n    createdBy?: unknown\n  }\n  void _id\n  void _c\n  void _u\n  void _ignoreSlug\n  void _ignoreBlocks\n  void _ignoreTranslatedFrom\n  void _ignoreCreatedBy\n  const base = (rest.title as string) ?? 'Lesson'\n  const newLesson = await payload.create({\n    collection: 'lessons',\n    data: {\n      ...rest,\n      title: `${base} - Variation (${level})`,\n      status: 'draft', // never publish a duplicate by default\n    } as never,\n    overrideAccess: true,\n  })\n  return newLesson.id\n}\n\n/**\n * Create a draft exercise in the output lesson with the generated blocks.\n * Returns the mapping entry for tracking.\n */\nasync function createOutputExercise(\n  payload: Payload,\n  result: StrategyResult,\n  outputLessonId: string,\n): Promise<OutputExerciseMapping> {\n  const ex = await payload.create({\n    collection: 'exercises',\n    data: {\n      title: `Variation of ${result.exerciseId}`,\n      lesson: outputLessonId,\n      content: { blocks: result.blocks },\n      status: 'draft',\n    } as never,\n    overrideAccess: true,\n  })\n  return {\n    sourceExerciseId: result.exerciseId,\n    outputExerciseId: ex.id,\n    strategy: result.strategy,\n  }\n}\n\n/**\n * Process a single exercise through the duplication pipeline.\n *\n * Steps:\n *  1. Run strategy → get new exercise content\n *  2. Structural validation → collect failures\n *  3. If structural passes AND strategy != 'script' → semantic validation\n *  4. On any failure: stream failure to DB, return null\n *  5. On all pass: return StrategyResult for the orchestrator to use\n */\nasync function processExercise(\n  exercise: ExerciseDoc,\n  duplicationId: string,\n  level: 'none' | 'light' | 'medium' | 'deep',\n  subject: DuplicationSubject,\n  payload: Payload,\n): Promise<{\n  result: StrategyResult | null\n  tokensUsed: { inputTokens: number; outputTokens: number }\n}> {\n  const exerciseRef = exercise.id\n\n  // Pre-trim source blocks. The structural validator caps exercises at 5\n  // blocks (TOO_MANY_SECTIONS — renderer / UX limit). Source exercises with\n  // 9-10 blocks would always fail variation. We sub-sample to 5 using the\n  // same scaling-random selector that picks exercises from a lesson: pick 1\n  // block per evenly-spaced bucket across the source, seeded for\n  // reproducibility. Preserves source order, so the variation feels like a\n  // natural truncation of the original.\n  const trimmedExercise = trimSourceBlocksIfNeeded(exercise)\n\n  // Step 1: Run strategy\n  let strategyResult: StrategyResult\n  let tokensUsed = { inputTokens: 0, outputTokens: 0 }\n  try {\n<<<<<<< HEAD\n    const strategyResponse = await runStrategy(exercise, level, subject, payload)\n    strategyResult = strategyResponse\n    tokensUsed = strategyResponse.tokensUsed\n=======\n    strategyResult = await runStrategy(trimmedExercise, level, subject, payload)\n>>>>>>> origin/dev\n  } catch (err) {\n    const message = err instanceof Error ? err.message : 'Unknown strategy error'\n    logger.error({ exerciseRef, level, err }, 'Strategy generation failed')\n    await appendFailure(payload, duplicationId, exerciseRef, 0, GENERATION_FAILURE_CODE, message)\n    return { result: null, tokensUsed }\n  }\n\n  // Step 2: Structural validation. Split failures into blocking (drop the\n  // exercise — renderer would crash) and warnings (admin fills from review\n  // screen). Warning-only exercises still ship, with TODO placeholders filled\n  // in for missing hint/solution/fullSolution so the lesson stays renderable.\n  //\n  // We pass the source exercise's blocks (post-trim) so the validator can\n  // suppress MISSING_QUESTION when the source itself had an empty prompt\n  // (e.g. legacy geometry exercises where the question is in the figure, not\n  // as text). Otherwise every such variation would falsely fail.\n  const sourceBlocks = (trimmedExercise.content?.blocks ?? []) as ContentBlock[]\n  const structuralFailures: StructuralFailure[] = validateExerciseStructural(\n    strategyResult.blocks,\n    sourceBlocks,\n  )\n  const blockingFailures = structuralFailures.filter((f) => BLOCKING_FAILURE_CODES.has(f.code))\n  const warningFailures = structuralFailures.filter((f) => !BLOCKING_FAILURE_CODES.has(f.code))\n\n  // Record blocking failures and non-blocking warnings into separate buckets\n  // so the review UI can show them under different headings.\n  for (const failure of blockingFailures) {\n    await appendFailure(\n      payload,\n      duplicationId,\n      exerciseRef,\n      failure.blockIndex ?? 0,\n      failure.code,\n      failure.message,\n    )\n  }\n  for (const warning of warningFailures) {\n    await appendWarning(\n      payload,\n      duplicationId,\n      exerciseRef,\n      warning.blockIndex ?? 0,\n      warning.code,\n      warning.message,\n    )\n  }\n\n  if (blockingFailures.length > 0) {\n    return { result: null, tokensUsed }\n  }\n\n  // Warning-only path: fill placeholders so the exercise renders. Warnings are\n  // already recorded so the admin can find the TODOs in the review screen.\n  if (warningFailures.length > 0) {\n    strategyResult = {\n      ...strategyResult,\n      blocks: fillMissingFieldsWithPlaceholders(strategyResult.blocks),\n    }\n  }\n\n  // Step 3: Semantic validation. Skipped for:\n  //  - level=none (deep clone, no AI variation to judge)\n  //  - script strategy (deterministic, no hallucination risk)\n  //  - warning-only path (we just inserted \"_TODO: hint not provided by AI_\"\n  //    placeholders; a semantic reviewer would flag those as nonsensical and\n  //    demote an exercise that should ship with a polish-later flag into a\n  //    hard failure)\n  if (strategyResult.strategy !== 'script' && level !== 'none' && warningFailures.length === 0) {\n    const semanticResult = await validateExerciseSemantic(\n      strategyResult.blocks,\n      level,\n      strategyResult.strategy,\n      payload,\n    )\n    if (!semanticResult.ok) {\n      await appendFailure(\n        payload,\n        duplicationId,\n        exerciseRef,\n        0,\n        SEMANTIC_FAILURE_CODE,\n        `Semantic mismatch: ${semanticResult.reasons.join('; ')}`,\n      )\n      return { result: null, tokensUsed }\n    }\n  }\n\n  return { result: strategyResult, tokensUsed }\n}\n\n/**\n * Reserve at least this much wall time (ms) at the end of a tick so the\n * orchestrator can write its final state to the DB before the platform\n * (Vercel) yanks the function. 30s covers a slow Mongo round-trip plus\n * Vercel's teardown grace.\n */\nconst FINALIZE_BUDGET_MS = 30_000\n\n/**\n * Default assumed worst-case time for one exercise (pass-1 + pass-2 +\n * validators on gemini-3.1-pro-preview). Used to decide whether the next\n * exercise can fit before the deadline. Conservative — if the run is\n * faster, we just process more per tick.\n */\nconst ASSUMED_EXERCISE_DURATION_MS = 300_000\n\nexport type RunOutcome = 'succeeded' | 'needs_review' | 'failed' | 'in_progress'\n\nexport interface RunOptions {\n  /**\n   * Absolute wall-clock deadline (Date.now() ms). The orchestrator returns\n   * `in_progress` as soon as the remaining time is too short to fit another\n   * exercise — leaving the record in `running` so the next cron tick picks\n   * up where this one left off. Default: no deadline (process all).\n   */\n  deadlineMs?: number\n}\n\n/**\n * Orchestrate the duplication pipeline for a single LessonDuplications record.\n * Resumable: skips exercises already processed in previous ticks and streams\n * each new output mapping to the DB as it completes. A Vercel function\n * timeout mid-run leaves a clean partial state — the next cron tick continues\n * from there.\n *\n * @param duplicationId  ID of the LessonDuplications record to process\n * @param payload        Payload instance\n * @param options.deadlineMs  Absolute timestamp by which to stop processing\n *\n * Pre-condition: record