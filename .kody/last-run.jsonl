{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_ppadlo0871cx_1","type":"tool_result","content":"1\t/**\n2\t * Integration test: lesson duplication orchestrator.\n3\t *\n4\t * Acceptance criteria:\n5\t *  1. Orchestrator runs at most 4 strategy calls in parallel\n6\t *  2. One exercise failing does not abort the run — remaining exercises complete\n7\t *  3. Failures appear in the DB record as the run progresses (live streaming, asserted by polling)\n8\t *  4. Final status is succeeded only when failures array is empty, else needs_review\n9\t *  5. 5-exercise lesson with one forced failure → needs_review with 4 succeeded + 1 failure entry\n10\t */\n11\timport { afterAll, beforeAll, beforeEach, describe, expect, it, vi } from 'vitest'\n12\timport { getPayload, type Payload } from 'payload'\n13\timport config from '@payload-config'\n14\t\n15\timport { getDefaultTenantSlug } from '@/server/repos/tenant/get-default-tenant'\n16\timport { runDuplicationOrchestrator } from '@/server/services/lesson-duplication/orchestrator'\n17\t\n18\t// Mock the variation service so AiVariationStrategy (used for medium/deep level)\n19\t// does not make real LLM calls in the integration test environment.\n20\t//\n21\t// Uses call-count tracking instead of ID pattern — Payload generates UUIDs for\n22\t// exercise IDs which don't contain '-3', so the old ID-based condition never triggered.\n23\t// Must be vi.hoisted: the vi.mock factory below runs hoisted above imports,\n24\t// so it may only close over hoisted refs. A plain `let` here makes the\n25\t// factory throw at runtime, silently falling back to the REAL variation\n26\t// service → real LLM call → flaky 180s timeout.\n27\tconst { mockState } = vi.hoisted(() => {\n28\t  let callCount = 0\n29\t  return {\n30\t    mockState: {\n31\t      reset() {\n32\t        callCount = 0\n33\t      },\n34\t      get next() {\n35\t        callCount++\n36\t        return callCount\n37\t      },\n38\t    },\n39\t  }\n40\t})\n41\t\n42\tvi.mock('@/infra/llm/services/lesson-duplication-variation-service', () => ({\n43\t  generateVariation: vi.fn().mockImplementation(\n44\t    async (\n45\t      input: { exercise: { id: string } },\n46\t      _payload: unknown,\n47\t    ): Promise<{\n48\t      exercise: { id: string; content: { blocks: unknown[] } }\n49\t      tokensUsed: { inputTokens: number; outputTokens: number }\n50\t    }> => {\n51\t      // Capture once — `mockState.next` is a getter that increments on\n52\t      // every read, so re-reading it inside the check would skip past 3.\n53\t      const callNumber = mockState.next\n54\t      // Force failure on the 3rd exercise (call count 3 = index 2)\n55\t      if (callNumber === 3) {\n56\t        throw new Error('Forced failure for test')\n57\t      }\n58\t      return {\n59\t        exercise: {\n60\t          id: input.exercise.id,\n61\t          content: {\n62\t            blocks: [\n63\t              {\n64\t                id: 'q-1',\n65\t                type: 'question_select',\n66\t                variant: 'mcq',\n67\t                selectionMode: 'single',\n68\t                prompt: {\n69\t                  type: 'rich_text',\n70\t                  format: 'md-math-v1',\n71\t                  value: 'What is 2+2?',\n72\t                  mediaIds: [],\n73\t                },\n74\t                answer: {\n75\t                  multiSelect: false,\n76\t                  options: [\n77\t                    {\n78\t                      id: 'a',\n79\t                      content: {\n80\t                        type: 'rich_text',\n81\t                        format: 'md-math-v1',\n82\t                        value: '3',\n83\t                        mediaIds: [],\n84\t                      },\n85\t                    },\n86\t                    {\n87\t                      id: 'b',\n88\t                      content: {\n89\t                        type: 'rich_text',\n90\t                        format: 'md-math-v1',\n91\t                        value: '4',\n92\t                        mediaIds: [],\n93\t                      },\n94\t                    },\n95\t                  ],\n96\t                  correctOptionIds: ['b'],\n97\t                },\n98\t                hint: {\n99\t                  type: 'rich_text',\n100\t                  format: 'md-math-v1',\n101\t                  value: 'Think arithmetic',\n102\t                  mediaIds: [],\n103\t                },\n104\t                solution: {\n105\t                  type: 'rich_text',\n106\t                  format: 'md-math-v1',\n107\t                  value: '2+2=4',\n108\t                  mediaIds: [],\n109\t                },\n110\t                fullSolution: {\n111\t                  type: 'rich_text',\n112\t                  format: 'md-math-v1',\n113\t                  value: 'Basic addition',\n114\t                  mediaIds: [],\n115\t                },\n116\t              },\n117\t            ],\n118\t          },\n119\t        },\n120\t        tokensUsed: { inputTokens: 0, outputTokens: 0 },\n121\t      }\n122\t    },\n123\t  ),\n124\t}))\n125\t\n126\tasync function ensureDefaultTenant(payload: Payload): Promise<string> {\n127\t  const slug = getDefaultTenantSlug()\n128\t  const existing = await payload.find({\n129\t    collection: 'tenants',\n130\t    where: { slug: { equals: slug } },\n131\t    limit: 1,\n132\t    overrideAccess: true,\n133\t  })\n134\t  if (existing.docs[0]) return existing.docs[0].id\n135\t  const created = await payload.create({\n136\t    collection: 'tenants',\n137\t    data: { name: slug, slug, status: 'active' },\n138\t    overrideAccess: true,\n139\t  })\n140\t  return created.id\n141\t}\n142\t\n143\t// Reset mock call count before each test to ensure the 3rd exercise always fails\n144\tbeforeEach(() => {\n145\t  mockState.reset()\n146\t})\n147\t\n148\tdescribe('Lesson duplication orchestrator — integration', () => {\n149\t  let payload: Payload\n150\t  let categoryId: string\n151\t