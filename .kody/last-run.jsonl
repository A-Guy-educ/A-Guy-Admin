{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_2tslhtd1acva_1","type":"tool_result","content":"1\t/**\n2\t * Integration test: lesson duplication orchestrator.\n3\t *\n4\t * Acceptance criteria:\n5\t *  1. Orchestrator runs at most 4 strategy calls in parallel\n6\t *  2. One exercise failing does not abort the run — remaining exercises complete\n7\t *  3. Failures appear in the DB record as the run progresses (live streaming, asserted by polling)\n8\t *  4. Final status is succeeded only when failures array is empty, else needs_review\n9\t *  5. 5-exercise lesson with one forced failure → needs_review with 4 succeeded + 1 failure entry\n10\t */\n11\timport { afterAll, beforeAll, beforeEach, describe, expect, it, vi } from 'vitest'\n12\timport { getPayload, type Payload } from 'payload'\n13\timport config from '@payload-config'\n14\t\n15\timport { getDefaultTenantSlug } from '@/server/repos/tenant/get-default-tenant'\n16\timport { runDuplicationOrchestrator } from '@/server/services/lesson-duplication/orchestrator'\n17\t\n18\t// Mock the variation service so AiVariationStrategy (used for medium/deep level)\n19\t// does not make real LLM calls in the integration test environment.\n20\t<<<<<<< HEAD\n21\t// Uses hoisted state for reliable module-level tracking across test runs.\n22\tconst { mockState } = vi.hoisted(() => {\n23\t  let callCount = 0\n24\t  return {\n25\t    mockState: {\n26\t      reset() {\n27\t        callCount = 0\n28\t      },\n29\t      get next() {\n30\t        callCount++\n31\t        return callCount\n32\t      },\n33\t    },\n34\t  }\n35\t})\n36\t\n37\t=======\n38\t// The variation service is only called when level != 'none' &&\n39\t// (level != 'light' || scriptStrategy.needsAiFallback).\n40\t// Uses call-count tracking instead of ID pattern — Payload generates UUIDs for\n41\t// exercise IDs which don't contain '-3', so the old ID-based condition never triggered.\n42\t// Must be vi.hoisted: the vi.mock factory below runs hoisted above imports,\n43\t// so it may only close over hoisted refs. A plain `let` here makes the\n44\t// factory throw at runtime, silently falling back to the REAL variation\n45\t// service → real LLM call → flaky 180s timeout.\n46\tconst h = vi.hoisted(() => ({ vgCallCount: 0 }))\n47\t>>>>>>> origin/dev\n48\tvi.mock('@/infra/llm/services/lesson-duplication-variation-service', () => ({\n49\t  generateVariation: vi.fn().mockImplementation(\n50\t    async (\n51\t      input: { exercise: { id: string } },\n52\t      _payload: unknown,\n53\t    ): Promise<{\n54\t      exercise: { id: string; content: { blocks: unknown[] } }\n55\t      tokensUsed: { inputTokens: number; outputTokens: number }\n56\t    }> => {\n57\t<<<<<<< HEAD\n58\t      // Capture once — `mockState.next` is a getter that increments on\n59\t      // every read, so re-reading it inside the check would skip past 3.\n60\t      const callNumber = mockState.next\n61\t      // Force failure on the 3rd exercise (call count 3 = index 2)\n62\t      if (callNumber === 3) {\n63\t=======\n64\t      h.vgCallCount++\n65\t      // Force failure on the 3rd exercise (call count 3 = index 2)\n66\t      if (h.vgCallCount === 3) {\n67\t>>>>>>> origin/dev\n68\t        throw new Error('Forced failure for test')\n69\t      }\n70\t      return {\n71\t        exercise: {\n72\t          id: input.exercise.id,\n73\t          content: {\n74\t            blocks: [\n75\t              {\n76\t                id: 'q-1',\n77\t                type: 'question_select',\n78\t                variant: 'mcq',\n79\t                selectionMode: 'single',\n80\t                prompt: {\n81\t                  type: 'rich_text',\n82\t                  format: 'md-math-v1',\n83\t                  value: 'What is 2+2?',\n84\t                  mediaIds: [],\n85\t                },\n86\t                answer: {\n87\t                  multiSelect: false,\n88\t                  options: [\n89\t                    {\n90\t                      id: 'a',\n91\t                      content: {\n92\t                        type: 'rich_text',\n93\t                        format: 'md-math-v1',\n94\t                        value: '3',\n95\t                        mediaIds: [],\n96\t                      },\n97\t                    },\n98\t                    {\n99\t                      id: 'b',\n100\t                      content: {\n101\t                        type: 'rich_text',\n102\t                        format: 'md-math-v1',\n103\t                        value: '4',\n104\t                        mediaIds: [],\n105\t                      },\n106\t                    },\n107\t                  ],\n108\t                  correctOptionIds: ['b'],\n109\t                },\n110\t                hint: {\n111\t                  type: 'rich_text',\n112\t                  format: 'md-math-v1',\n113\t                  value: 'Think arithmetic',\n114\t                  mediaIds: [],\n115\t                },\n116\t                solution: {\n117\t                  type: 'rich_text',\n118\t                  format: 'md-math-v1',\n119\t                  value: '2+2=4',\n120\t                  mediaIds: [],\n121\t                },\n122\t                fullSolution: {\n123\t                  type: 'rich_text',\n124\t                  format: 'md-math-v1',\n125\t                  value: 'Basic addition',\n126\t                  mediaIds: [],\n127\t                },\n128\t              },\n129\t            ],\n130\t          },\n131\t        },\n132\t        tokensUsed: { inputTokens: 0, outputTokens: 0 },\n133\t      }\n134\t    },\n135\t  ),\n136\t}))\n137\t\n138\tasync function ensureDefaultTenant(payload: Payload): Promise<string> {\n139\t  const slug = getDefaultTenantSlug()\n140\t  const existing = await payload.find({\n141\t    collection: 'tenants',\n142\t    where: { slug: { equals: slug } },\n143\t    limit: 1,\n144\t    overrideAccess: true,\n145\t  })\n146\t  if (existing.docs[0]) return existing.docs[0].id\n147\t  const created = await payload.create({\n148\t    collection: 'tenants',\n149\t    data: { name: slug, slug, status: 'active' },\n150\t    overrideAccess: true,\n151\t  })\n152\t  return created.id\n153\t}\n154\t\n155\t// Reset mock call count before each test to ensure the 3rd exercise always fails\n156\tbeforeEach(() => {\n157\t  mockState.reset()\n158\t})\n159\t\n160\tdescribe('Lesson duplication orchestrator — integration', () => {\n161\t  let payload: Payload\n162\t  let categoryId: string\n163\t  let courseId: string\n164\t  let chapterId: string\n165\t  let tenantId: string\n166\t  let sourceLessonId: string\n167\t  const cleanupLessonIds: string[] = []\n168\t  const cleanupExerciseIds: string[] = []\n169\t  const cleanupDuplicationIds: string[] = []\n170\t\n171\t  beforeEach(() => {\n172\t<<<<<<< HEAD\n173\t    mockState.reset()\n174\t=======\n175\t    h.vgCallCount = 0\n176\t>>>>>>> origin/dev\n177\t  })\n178\t\n179\t  beforeAll(async () => {\n180\t    payload = await getPayload({ config })\n181\t    tenantId = await ensureDefaultTenant(payload)\n182\t    const ts = Date.now()\n183\t\n184\t    const category = await payload.create({\n185\t      collection: 'categories',\n186\t      data: { title: `OrchCat ${ts}`, slug: `orch-cat-${ts}`, locale: 'he' },\n187\t    })\n188\t    categoryId = category.id\n189\t\n190\t    const course = await payload.create({\n191\t      collection: 'courses',\n192\t      data: {\n193\t        courseLabel: `ORCH-${ts}`,\n194\t        title: `Orch Course ${ts}`,\n195\t        locale: 'he',\n196\t        categories: [categoryId],\n197\t        order: 0,\n198\t        status: 'published',\n199\t        isActive: true,\n200\t        tenant: tenantId,\n201\t        pageAccessType: 'free',\n202\t        accessType: 'free',\n203\t        contentStatus: 'none',\n204\t        contentStatusVisible: true,\n205\t      },\n206\t      draft: false,\n207\t    })\n208\t    courseId = course.id\n209\t\n210\t    const chapter = await payload.create({\n211\t      collection: 'chapters',\n212\t      data: {\n213\t        title: `Orch Chapter ${ts}`,\n214\t        chapterLabel: `OCH-${ts}`,\n215\t        course: courseId,\n216\t        order: 0,\n217\t        status: 'published',\n218\t        isActive: true,\n219\t        tenant: tenantId,\n220\t        locale: 'he',\n221\t      },\n222\t    })\n223\t    chapterId = chapter.id\n224\t\n225\t    const lesson = await payload.create({\n226\t      collection: 'lessons',\n227\t      data: {\n228\t        title: `Orch Source Lesson ${ts}`,\n229\t        chapter: chapterId,\n230\t        type: 'practice',\n231\t        order: 1,\n232\t        status: 'published',\n233\t        isActive: true,\n234\t        tenant: tenantId,\n235\t        locale: 'he',\n236\t        accessType: 'inherit',\n237\t        contentStatus: 'none',\n238\t        contentStatusVisible: true,\n239\t      },\n240\t      draft: false,\n241\t    })\n242\t    sourceLessonId = lesson.id\n243\t    cleanupLessonIds.push(sourceLessonId)\n244\t\n245\t    // Create exactly 5 exercises on the source lesson\n246\t    for (let i = 0; i < 5; i++) {\n247\t      const ex = await payload.create({\n248\t        collection: 'exercises',\n249\t        data: { title: `Orch Exercise ${i} ${ts}`, lesson: sourceLessonId },\n250\t        draft: true,\n251\t      })\n252\t      cleanupExerciseIds.push(ex.id)\n253\t    }\n254\t  }, 120000)\n255\t\n256\t  afterAll(async () => {\n257\t    for (const id of cleanupDuplicationIds) {\n258\t      try {\n259\t        await payload.delete({ collection: 'lesson-duplications', id, overrideAccess: true })\n260\t      } catch {\n261\t        /* ignore */\n262\t      }\n263\t    }\n264\t    for (const id of cleanupExerciseIds) {\n265\t      try {\n266\t        await payload.delete({ collection: 'exercises', id, overrideAccess: true })\n267\t      } catch {\n268\t        /* ignore */\n269\t      }\n270\t    }\n271\t    for (const id of cleanupLessonIds) {\n272\t      try {\n273\t        await payload.delete({ collection: 'lessons', id, overrideAccess: true })\n274\t      } catch {\n275\t        /* ignore */\n276\t      }\n277\t    }\n278\t    try {\n279\t      await payload.delete({ collection: 'chapters', id: chapterId, overrideAccess: true })\n280\t    } catch {\n281\t      /* ignore */\n282\t    }\n283\t    try {\n284\t      await payload.delete({ collection: 'courses', id: courseId, overrideAccess: true })\n285\t    } catch {\n286\t      /* ignore */\n287\t    }\n288\t    try {\n289\t      await payload.delete({ collection: 'categories', id: categoryId, overrideAccess: true })\n290\t    } catch {\n291\t      /* ignore */\n292\t    }\n293\t    await payload.db?.destroy?.()\n294\t  })\n295\t\n296\t  /**\n297\t   * Poll the duplication record until status is no longer 'running' or 'pending'.\n298\t   * Returns the final record state.\n299\t   */\n300\t  async function pollUntilDone(recordId: string): Promise<{\n301\t    status: string\n302\t    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n303\t    failures: any[]\n304\t\n305\t    outputLesson?: string | null\n306\t    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n307\t    outputExercises?: any[]\n308\t  }> {\n309\t    let record = await payload.findByID({\n310\t      collection: 'lesson-duplications',\n311\t      id: recordId,\n312\t      depth: 0,\n313\t      overrideAccess: true,\n314\t    })\n315\t    const deadline = Date.now() + 30000\n316\t    while ((record.status === 'running' || record.status === 'pending') && Date.now() < deadline) {\n317\t      await new Promise((r) => setTimeout(r, 500))\n318\t      record = await payload.findByID({\n319\t        collection: 'lesson-duplications',\n320\t        id: recordId,\n321\t        depth: 0,\n322\t        overrideAccess: true,\n323\t      })\n324\t    }\n325\t    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n326\t    return record as any\n327\t  }\n328\t\n329\t  it('5-exercise lesson with one forced failure ends in needs_review with failures recorded', async () => {\n330\t    // Create pending duplication record\n331\t    const record = await payload.create({\n332\t      collection: 'lesson-duplications',\n333\t      data: { sourceLesson: sourceLessonId, level: 'medium', status: 'pending' },\n334\t      overrideAccess: true,\n335\t    })\n336\t    cleanupDuplicationIds.push(record.id)\n337\t\n338\t    expect(record.status).toBe('pending')\n339\t\n340\t    // Run orchestrator (mocked runStrategy forces failure on exercise containing '-3')\n341\t    try {\n342\t      await runDuplicationOrchestrator(record.id, payload)\n343\t    } catch {\n344\t      // Orchestrator may throw if the mock is not properly applied;\n345\t      // we still verify the DB record state below\n346\t    }\n347\t\n348\t    // Poll until done\n349\t    const finalRecord = await pollUntilDone(record.id)\n350\t\n351\t    // Final status must be needs_review (not succeeded, not failed)\n352\t    expect(finalRecord.status).toBe('needs_review')\n353\t\n354\t    // At least one failure entry expected (exercise containing '-3' threw in runStrategy)\n355\t    // Note: the exact count depends on exercise ID strings; we check ≥1 to be robust\n356\t    expect(finalRecord.failures).toBeDefined()\n357\t    expect(finalRecord.failures.length).toBeGreaterThanOrEqual(1)\n358\t    expect(finalRecord.failures[0].code).toBe('GENERATION_FAILED')\n359\t    expect(finalRecord.failures[0].suggestedAction).toBe('skip')\n360\t\n361\t    // After orchestrator runs, outputLesson should be created\n362\t    // Note: outputExercises remain empty in this test because the runStrategy mock\n363\t    // bypasses processExercise (which calls createOutputExercise). Exercise creation\n364\t    // is verified in lesson-duplication-review-resolve.int.spec.ts instead.\n365\t    expect(finalRecord.outputLesson).toBeTruthy()\n366\t  }, 180000)\n367\t\n368\t  it('orchestrator does not abort when one exercise fails — remaining exercises are processed', async () => {\n369\t    // Create fresh pending record\n370\t    const record = await payload.create({\n371\t      collection: 'lesson-duplications',\n372\t      data: { sourceLesson: sourceLessonId, level: 'medium', status: 'pending' },\n373\t      overrideAccess: true,\n374\t    })\n375\t    cleanupDuplicationIds.push(record.id)\n376\t\n377\t    // Run orchestrator; it may throw if the mock isn't applied (that's ok for this test)\n378\t    try {\n379\t      await runDuplicationOrchestrator(record.id, payload)\n380\t    } catch {\n381\t      // ignore\n382\t    }\n383\t\n384\t    const finalRecord = await pollUntilDone(record.id)\n385\t\n386\t    // The orchestrator should reach needs_review (not 'failed'), meaning it processed\n387\t    // exercises and collected failures rather than crashing completely.\n388\t    // If the orchestrator crashed early, status would be 'failed' with 0 failures.\n389\t    expect(finalRecord.status).toBe('needs_review')\n390\t\n391\t    // At least one failure means at least one exercise failed and the orchestrator\n392\t    // continued processing other exercises (did not abort on first failure).\n393\t    expect(finalRecord.failures).toBeDefined()\n394\t    expect(finalRecord.failures.length).toBeGreaterThanOrEqual(1)\n395\t    expect(finalRecord.failures[0].code).toBe('GENERATION_FAILED')\n396\t\n397\t    // outputLesson should be created even when some exercises fail\n398\t    expect(finalRecord.outputLesson).toBeTruthy()\n399\t  }, 180000)\n400\t})\n401\t"}]},"parent_tool_use_id":null,"session_id":"34893b8c-baac-4aa8-aac8-754096b92693","uuid":"8889ae9b-3c55-4248-b82b-7ca4251fbb30","timestamp":"2026-05-19T14:14:16.397Z","tool_use_result":{"type":"text","file":{"filePath":"/home/runner/work/A-Guy/A-Guy/tests/int/lesson-duplication-orchestrator.int.spec.ts","content":"/**\n * Integration test: lesson duplication orchestrator.\n *\n * Acceptance criteria:\n *  1. Orchestrator runs at most 4 strategy calls in parallel\n *  2. One exercise failing does not abort the run — remaining exercises complete\n *  3. Failures appear in the DB record as the run progresses (live streaming, asserted by polling)\n *  4. Final status is succeeded only when failures array is empty, else needs_review\n *  5. 5-exercise lesson with one forced failure → needs_review with 4 succeeded + 1 failure entry\n */\nimport { afterAll, beforeAll, beforeEach, describe, expect, it, vi } from 'vitest'\nimport { getPayload, type Payload } from 'payload'\nimport config from '@payload-config'\n\nimport { getDefaultTenantSlug } from '@/server/repos/tenant/get-default-tenant'\nimport { runDuplicationOrchestrator } from '@/server/services/lesson-duplication/orchestrator'\n\n// Mock the variation service so AiVariationStrategy (used for medium/deep level)\n// does not make real LLM calls in the integration test environment.\n<<<<<<< HEAD\n// Uses hoisted state for reliable module-level tracking across test runs.\nconst { mockState } = vi.hoisted(() => {\n  let callCount = 0\n  return {\n    mockState: {\n      reset() {\n        callCount = 0\n      },\n      get next() {\n        callCount++\n        return callCount\n      },\n    },\n  }\n})\n\n=======\n// The variation service is only called when level != 'none' &&\n// (level != 'light' || scriptStrategy.needsAiFallback).\n// Uses call-count tracking instead of ID pattern — Payload generates UUIDs for\n// exercise IDs which don't contain '-3', so the old ID-based condition never triggered.\n// Must be vi.hoisted: the vi.mock factory below runs hoisted above imports,\n// so it may only close over hoisted refs. A plain `let` here makes the\n// factory throw at runtime, silently falling back to the REAL variation\n// service → real LLM call → flaky 180s timeout.\nconst h = vi.hoisted(() => ({ vgCallCount: 0 }))\n>>>>>>> origin/dev\nvi.mock('@/infra/llm/services/lesson-duplication-variation-service', () => ({\n  generateVariation: vi.fn().mockImplementation(\n    async (\n      input: { exercise: { id: string } },\n      _payload: unknown,\n    ): Promise<{\n      exercise: { id: string; content: { blocks: unknown[] } }\n      tokensUsed: { inputTokens: number; outputTokens: number }\n    }> => {\n<<<<<<< HEAD\n      // Capture once — `mockState.next` is a getter that increments on\n      // every read, so re-reading it inside the check would skip past 3.\n      const callNumber = mockState.next\n      // Force failure on the 3rd exercise (call count 3 = index 2)\n      if (callNumber === 3) {\n=======\n      h.vgCallCount++\n      // Force failure on the 3rd exercise (call count 3 = index 2)\n      if (h.vgCallCount === 3) {\n>>>>>>> origin/dev\n        throw new Error('Forced failure for test')\n      }\n      return {\n        exercise: {\n          id: input.exercise.id,\n          content: {\n            blocks: [\n              {\n                id: 'q-1',\n                type: 'question_select',\n                variant: 'mcq',\n                selectionMode: 'single',\n                prompt: {\n                  type: 'rich_text',\n                  format: 'md-math-v1',\n                  value: 'What is 2+2?',\n                  mediaIds: [],\n                },\n                answer: {\n                  multiSelect: false,\n                  options: [\n                    {\n                      id: 'a',\n                      content: {\n                        type: 'rich_text',\n                        format: 'md-math-v1',\n                        value: '3',\n                        mediaIds: [],\n                      },\n                    },\n                    {\n                      id: 'b',\n                      content: {\n                        type: 'rich_text',\n                        format: 'md-math-v1',\n                        value: '4',\n                        mediaIds: [],\n                      },\n                    },\n                  ],\n                  correctOptionIds: ['b'],\n                },\n                hint: {\n                  type: 'rich_text',\n                  format: 'md-math-v1',\n                  value: 'Think arithmetic',\n                  mediaIds: [],\n                },\n                solution: {\n                  type: 'rich_text',\n                  format: 'md-math-v1',\n                  value: '2+2=4',\n                  mediaIds: [],\n                },\n                fullSolution: {\n                  type: 'rich_text',\n                  format: 'md-math-v1',\n                  value: 'Basic addition',\n                  mediaIds: [],\n                },\n              },\n            ],\n          },\n        },\n        tokensUsed: { inputTokens: 0, outputTokens: 0 },\n      }\n    },\n  ),\n}))\n\nasync function ensureDefaultTenant(payload: Payload): Promise<string> {\n  const slug = getDefaultTenantSlug()\n  const existing = await payload.find({\n    collection: 'tenants',\n    where: { slug: { equals: slug } },\n    limit: 1,\n    overrideAccess: true,\n  })\n  if (existing.docs[0]) return existing.docs[0].id\n  const created = await payload.create({\n    collection: 'tenants',\n    data: { name: slug, slug, status: 'active' },\n    overrideAccess: true,\n  })\n  return created.id\n}\n\n// Reset mock call count before each test to ensure the 3rd exercise always fails\nbeforeEach(() => {\n  mockState.reset()\n})\n\ndescribe('Lesson duplication orchestrator — integration', () => {\n  let payload: Payload\n  let categoryId: string\n  let courseId: string\n  let chapterId: string\n  let tenantId: string\n  let sourceLessonId: string\n  const cleanupLessonIds: string[] = []\n  const cleanupExerciseIds: string[] = []\n  const cleanupDuplicationIds: string[] = []\n\n  beforeEach(() => {\n<<<<<<< HEAD\n    mockState.reset()\n=======\n    h.vgCallCount = 0\n>>>>>>> origin/dev\n  })\n\n  beforeAll(async () => {\n    payload = await getPayload({ config })\n    tenantId = await ensureDefaultTenant(payload)\n    const ts = Date.now()\n\n    const category = await payload.create({\n      collection: 'categories',\n      data: { title: `OrchCat ${ts}`, slug: `orch-cat-${ts}`, locale: 'he' },\n    })\n    categoryId = category.id\n\n    const course = await payload.create({\n      collection: 'courses',\n      data: {\n        courseLabel: `ORCH-${ts}`,\n        title: `Orch Course ${ts}`,\n        locale: 'he',\n        categories: [categoryId],\n        order: 0,\n        status: 'published',\n        isActive: true,\n        tenant: tenantId,\n        pageAccessType: 'free',\n        accessType: 'free',\n        contentStatus: 'none',\n        contentStatusVisible: true,\n      },\n      draft: false,\n    })\n    courseId = course.id\n\n    const chapter = await payload.create({\n      collection: 'chapters',\n      data: {\n        title: `Orch Chapter ${ts}`,\n        chapterLabel: `OCH-${ts}`,\n        course: courseId,\n        order: 0,\n        status: 'published',\n        isActive: true,\n        tenant: tenantId,\n        locale: 'he',\n      },\n    })\n    chapterId = chapter.id\n\n    const lesson = await payload.create({\n      collection: 'lessons',\n      data: {\n        title: `Orch Source Lesson ${ts}`,\n        chapter: chapterId,\n        type: 'practice',\n        order: 1,\n        status: 'published',\n        isActive: true,\n        tenant: tenantId,\n        locale: 'he',\n        accessType: 'inherit',\n        contentStatus: 'none',\n        contentStatusVisible: true,\n      },\n      draft: false,\n    })\n    sourceLessonId = lesson.id\n    cleanupLessonIds.push(sourceLessonId)\n\n    // Create exactly 5 exercises on the source lesson\n    for (let i = 0; i < 5; i++) {\n      const ex = await payload.create({\n        collection: 'exercises',\n        data: { title: `Orch Exercise ${i} ${ts}`, lesson: sourceLessonId },\n        draft: true,\n      })\n      cleanupExerciseIds.push(ex.id)\n    }\n  }, 120000)\n\n  afterAll(async () => {\n    for (const id of cleanupDuplicationIds) {\n      try {\n        await payload.delete({ collection: 'lesson-duplications', id, overrideAccess: true })\n      } catch {\n        /* ignore */\n      }\n    }\n    for (const id of cleanupExerciseIds) {\n      try {\n        await payload.delete({ collection: 'exercises', id, overrideAccess: true })\n      } catch {\n        /* ignore */\n      }\n    }\n    for (const id of cleanupLessonIds) {\n      try {\n        await payload.delete({ collection: 'lessons', id, overrideAccess: true })\n      } catch {\n        /* ignore */\n      }\n    }\n    try {\n      await payload.delete({ collection: 'chapters', id: chapterId, overrideAccess: true })\n    } catch {\n      /* ignore */\n    }\n    try {\n      await payload.delete({ collection: 'courses', id: courseId, overrideAccess: true })\n    } catch {\n      /* ignore */\n    }\n    try {\n      await payload.delete({ collection: 'categories', id: categoryId, overrideAccess: true })\n    } catch {\n      /* ignore */\n    }\n    await payload.db?.destroy?.()\n  })\n\n  /**\n   * Poll the duplication record until status is no longer 'running' or 'pending'.\n   * Returns the final record state.\n   */\n  async function pollUntilDone(recordId: string): Promise<{\n    status: string\n    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n    failures: any[]\n\n    outputLesson?: string | null\n    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n    outputExercises?: any[]\n  }> {\n    let record = await payload.findByID({\n      collection: 'lesson-duplications',\n      id: recordId,\n      depth: 0,\n      overrideAccess: true,\n    })\n    const deadline = Date.now() + 30000\n    while ((record.status === 'running' || record.status === 'pending') && Date.now() < deadline) {\n      await new Promise((r) => setTimeout(r, 500))\n      record = await payload.findByID({\n        collection: 'lesson-duplications',\n        id: recordId,\n        depth: 0,\n        overrideAccess: true,\n      })\n    }\n    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n    return record as any\n  }\n\n  it('5-exercise lesson with one forced failure ends in needs_review with failures recorded', async () => {\n    // Create pending duplication record\n    const record = await payload.create({\n      collection: 'lesson-duplications',\n      data: { sourceLesson: sourceLessonId, level: 'medium', status: 'pending' },\n      overrideAccess: true,\n    })\n    cleanupDuplicationIds.push(record.id)\n\n    expect(record.status).toBe('pending')\n\n    // Run orchestrator (mocked runStrategy forces failure on exercise containing '-3')\n    try {\n      await runDuplicationOrchestrator(record.id, payload)\n    } catch {\n      // Orchestrator may throw if the mock is not properly applied;\n      // we still verify the DB record state below\n    }\n\n    // Poll until done\n    const finalRecord = await pollUntilDone(record.id)\n\n    // Final status must be needs_review (not succeeded, not failed)\n    expect(finalRecord.status).toBe('needs_review')\n\n    // At least one failure entry expected (exercise containing '-3' threw in runStrategy)\n    // Note: the exact count depends on exercise ID strings; we check ≥1 to be robust\n    expect(finalRecord.failures).toBeDefined()\n    expect(finalRecord.failures.length).toBeGreaterThanOrEqual(1)\n    expect(finalRecord.failures[0].code).toBe('GENERATION_FAILED')\n    expect(finalRecord.failures[0].suggestedAction).toBe('skip')\n\n    // After orchestrator runs, outputLesson should be created\n    // Note: outputExercises remain empty in this test because the runStrategy mock\n    // bypasses processExercise (which calls createOutputExercise). Exercise creation\n    // is verified in lesson-duplication-review-resolve.int.spec.ts instead.\n    expect(finalRecord.outputLesson).toBeTruthy()\n  }, 180000)\n\n  it('orchestrator does not abort when one exercise fails — remaining exercises are processed', async () => {\n    // Create fresh pending record\n    const record = await payload.create({\n      collection: 'lesson-duplications',\n      data: { sourceLesson: sourceLessonId, level: 'medium', status: 'pending' },\n      overrideAccess: true,\n    })\n    cleanupDuplicationIds.push(record.id)\n\n    // Run orchestrator; it may throw if the mock isn't applied (that's ok for this test)\n    try {\n      await runDuplicationOrchestrator(record.id, payload)\n    } catch {\n      // ignore\n    }\n\n    const finalRecord = await pollUntilDone(record.id)\n\n    // The orchestrator should reach needs_review (not 'failed'), meaning it processed\n    // exercises and collected failures rather than crashing completely.\n    // If the orchestrator crashed early, status would be 'failed' with 0 failures.\n    expect(finalRecord.status).toBe('needs_review')\n\n    // At least one failure means at least one exercise failed and the orchestrator\n    // continued processing other exercises (did not abort on first failure).\n    expect(finalRecord.failures).toBeDefined()\n    expect(finalRecord.failures.length).toBeGreaterThanOrEqual(1)\n    expect(finalRecord.failures[0].code).toBe('GENERATION_FAILED')\n\n    // outputLesson should be created even when some exercises fail\n    expect(finalRecord.outputLesson).toBeTruthy()\n  }, 180000)\n})\n","numLines":401,"startLine":1,"totalLines":401}}}
