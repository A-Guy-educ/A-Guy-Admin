{
  "$schema": "https://raw.githubusercontent.com/aharonyaircohen/Kody-Engine-Lite/main/kody.config.schema.json",
  "quality": {
    "typecheck": "pnpm typecheck",
    "lint": "pnpm lint",
    "format": "pnpm format",
    "testUnit": "pnpm test:unit:coverage"
  },
  "git": {
    "defaultBranch": "dev"
  },
  "github": {
    "owner": "A-Guy-educ",
    "repo": "A-Guy-Admin",
    "operators": [
      "aguyaharonyair"
    ]
  },
  "state": {
    "repo": "https://github.com/A-Guy-educ/kody-state",
    "path": "A-Guy-Admin",
    "branch": "main"
  },
  "agent": {
    "model": "minimax/MiniMax-M3"
  },
  "qa": {
    "fallbackUrl": "https://dev.aguy.co.il"
  },
  "release": {
    "releaseBranch": "main",
    "versionFiles": [
      "package.json"
    ],
    "e2eCommand": "npx tsx scripts/release-e2e-gate.ts",
    "timeoutMs": 1800000
  },
  "jobs": {
    "stateBackend": "contents-api"
  },
  "defaultExecutable": "classify",
  "defaultPrExecutable": "fix",
  "onPullRequest": "preview-build",
  "access": {
    "allowedAssociations": [
      "OWNER",
      "COLLABORATOR",
      "CONTRIBUTOR",
      "FIRST_TIME_CONTRIBUTOR",
      "MEMBER"
    ]
  },
  "company": {
    "activeGoals": [
      "ci-health",
      "prs-stay-mergeable",
      "ai-agency-health",
      "product-quality"
    ],
    "activeCapabilities": [
      "capability-call",
      "classify",
      "research",
      "plan",
      "feature",
      "bug",
      "chore",
      "spec",
      "review",
      "fix",
      "fix-ci",
      "ci-health",
      "dev-ci-health",
      "pr-health-triage",
      "redispatch",
      "sync",
      "resolve",
      "merge",
      "revert",
      "release-prepare",
      "release-merge",
      "release-promote",
      "vercel-production-deploy",
      "design-review",
      "preview-health",
      "qa",
      "qa-engineer",
      "qa-goal",
      "qa-sweep",
      "qa-verify",
      "quality-watch",
      "ui-review"
    ],
    "activeAgents": [
      "ceo",
      "cto",
      "kody",
      "qa",
      "repo-brain",
      "tech-writer",
      "ux-designer"
    ]
  },
  "fly": {
    "previews": {
      "cpus": 2,
      "memoryMb": 2048,
      "ttlDays": 14,
      "builderCpus": 8,
      "builderMemoryMb": 8192,
      "idleSuspend": true,
      "healthCheck": false
    }
  }
}
