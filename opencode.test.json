{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [".ai-docs/BOOTSTRAP.md", ".ai-docs/quick-reference/CHEAT-SHEET.md"],
  "agent": {
    "build": {
      "model": "opencode/mimo-v2-flash-free",
      "description": "Building features (TEST - cheap model)"
    },
    "plan": {
      "model": "opencode/mimo-v2-flash-free",
      "description": "Planning tasks (TEST - cheap model)"
    },
    "architect": {
      "model": "opencode/mimo-v2-flash-free",
      "description": "Architecture design (TEST - cheap model)"
    },
    "clarify": {
      "model": "opencode/mimo-v2-flash-free",
      "description": "Collects questions (TEST - cheap model)"
    },
    "taskify": {
      "model": "opencode/mimo-v2-flash-free",
      "description": "Creates task.json (TEST - cheap model)"
    },
    "gap": {
      "model": "opencode/mimo-v2-flash-free",
      "description": "Analyzes gaps (TEST - cheap model)"
    },
    "plan-gap": {
      "model": "opencode/mimo-v2-flash-free",
      "description": "Analyzes plan gaps (TEST - cheap model)"
    },
    "autofix": {
      "model": "opencode/mimo-v2-flash-free",
      "description": "Auto-fixes (TEST - cheap model)"
    },
    "verify": {
      "model": "opencode/mimo-v2-flash-free",
      "description": "Runs tests (TEST - cheap model)"
    },
    "test": {
      "model": "opencode/mimo-v2-flash-free",
      "description": "Writes tests (TEST - cheap model)"
    },
    "advisor": {
      "model": "opencode/mimo-v2-flash-free",
      "description": "Code review (TEST - cheap model)"
    },
    "pr": {
      "model": "opencode/mimo-v2-flash-free",
      "description": "Creates PR (TEST - cheap model)"
    },
    "cody-expert": {
      "model": "opencode/mimo-v2-flash-free",
      "description": "Pipeline expert (TEST - cheap model)"
    },
    "build-manager": {
      "model": "opencode/mimo-v2-flash-free",
      "description": "Orchestration (TEST - cheap model)"
    },
    "test-writer": {
      "model": "opencode/mimo-v2-flash-free",
      "description": "TDD writer (TEST - cheap model)"
    },
    "browser": {
      "model": "opencode/mimo-v2-flash-free",
      "description": "Browser agent (TEST - cheap model)"
    },
    "review": {
      "model": "opencode/mimo-v2-flash-free",
      "description": "Code review (TEST - cheap model)"
    },
    "fix": {
      "model": "opencode/mimo-v2-flash-free",
      "description": "Targeted fixes (TEST - cheap model)"
    },
    "reflect": {
      "model": "opencode/mimo-v2-flash-free",
      "description": "Reflection (TEST - cheap model)"
    },
    "e2e-test-writer": {
      "model": "opencode/mimo-v2-flash-free",
      "description": "E2E tests (TEST - cheap model)"
    }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--isolated=true",
        "--no-usage-statistics"
      ]
    },
    "figma": {
      "type": "local",
      "command": ["npx", "-y", "figma-developer-mcp", "--figma-api-key=${FIGMA_API_KEY}", "--stdio"]
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest",
        "--headless",
        "--caps=vision,devtools,pdf",
        "--storage-state=scripts/browser-agent/.auth/storage-state.json",
        "--test-id-attribute=data-testid",
        "--console-level=info",
        "--viewport-size=1280x720"
      ]
    }
  }
}
